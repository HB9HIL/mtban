#!/usr/bin/make -f

include /usr/share/dpkg/architecture.mk

# Map Debian arch to GOARCH/GOARM for cross-compilation.
ifeq ($(DEB_HOST_ARCH),arm64)
  GOARCH := arm64
  GOARM  :=
else ifeq ($(DEB_HOST_ARCH),armhf)
  GOARCH := arm
  GOARM  := 7
else
  GOARCH := amd64
  GOARM  :=
endif

override_dh_auto_build:
	mkdir -p dist
	GOARCH=$(GOARCH) GOARM=$(GOARM) go build -trimpath -ldflags "-s -w" -o dist/mtban .

override_dh_auto_install:

override_dh_auto_test:

override_dh_auto_clean:
	rm -rf dist/

%:
	dh $@
